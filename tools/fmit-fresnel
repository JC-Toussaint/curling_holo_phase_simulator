def coherence(I, dx, dy, alpha):
    ''' I is the intensity, convolution in real space with gaussian function
    '''
    Ny, Nx = I.shape
    x = (np.arange(Nx) - (Nx - 1) / 2)*dx
    y = (np.arange(Ny) - (Ny - 1) / 2)*dy
    X, Y = np.meshgrid(x, y)

    if alpha==0:
        return I
    else:
        alpha_R = 1/(4*alpha)
        print("alpha for divergence in image plane (m^-2)= ", alpha_R)
        G = np.exp(-alpha_R*(X**2 + Y**2)) #gaussian exp(-alpha*r^2)
        G /= G.sum()          # normalisation
        return fftconvolve(I, G, mode='same')

def amplitude(I, length, crop, elec=1): #elec = nb d'electrons pour match experimental image, data
    ''' attempt of fitting experimental image amplitude '''
    Nx, Ny = length.shape
    if crop==True:
        y1 = Ny + math.ceil(Ny/4)
        y2 = 2*Ny - math.ceil(Ny/4)
        x1 = Nx + math.ceil(Nx/4)
        x2 = 2*Nx - math.ceil(Nx/4)
        length_ampl=length[y1:y2,x1:x2]
    else:
        length_ampl=length
    norm_length=length_ampl/np.max(length_ampl) #error here to be corrected
    Id = np.ones_like(I)
    ampl = Id*elec-0.5*elec*norm_length
    return I*ampl

def add_elec_phase(phase, length, Ce, V0):
    ''' add electrostatic component to the phase '''
    return phase + length*Ce*V0

def str2bool(v):    
    ''' convert string to boolean '''
    if isinstance(v, bool):
        return v
    if v.lower() in ("yes", "true", "t", "1"):
        return True
    elif v.lower() in ("no", "false", "f", "0"):
        return False
    else:
        raise argparse.ArgumentTypeError("Boolean value expected.")
    
def parse_args(): #ajouter option alpha pour la coherence du faisceau
    ''' parsing of the command line '''
    p = argparse.ArgumentParser()
    p.add_argument("phaseFileName", help="phase map file in a PNG container unsigned 16-bit")
    p.add_argument("thicknessMapFileName", help="thickness map file in a PNG container unsigned 16-bit")
    p.add_argument("--version",action='version',version=__version__, help="show the version number")
    p.add_argument("--defocus", type=float, default=0.5E-3, help="defocusing parameter in m, default= 0.5e-3 m")
    p.add_argument("--convergence", type=float, default=0.001E-3, help="convergence in rad, default= 1e-6 rad")
    p.add_argument("--E0", type=float, default=200e3, help="Voltage E0 in eV, default= 2e5 eV")
    p.add_argument("--Cs", type=float, default=1.2e-3, help="Constant Cs in m, default= 1.2e-3 m")
    p.add_argument("--V0", type=float, default=20, help="Voltage V0 in V, default= 20 V")
    p.add_argument("--crop", type=str2bool, default=False, help="Enable cropping (true/false), default= False") #change crop to false if full image
    p.add_argument("--mode", type=str, default="default", help="Available options: mirrored|default, default= default")

    return p.parse_args()

