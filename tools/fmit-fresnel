from scipy.constants import c #speed of light in vacuum

def relativistic_wavelength(eV):
    E = eV * e
    p = np.sqrt(E**2 + 2*E*m_e*c**2) / c
    return h / p

def electrical_constant(eV):
    lam=relativistic_wavelength(eV)
    E_0=m_e*c**2
    E = eV * e #microscope acceleration, in eV
    gamma= 1+ E/E_0 #relativistic Lorentz factor
    U_s=eV*(1+gamma)/2 #relativistic corrected potential
    return (np.pi*gamma)/(lam*U_s)
    #return (2*np.pi*e/(lam*eV))*(eV+E_0)/(eV+2*E_0)

def find_meta_value(meta, patterns):
    """Cherche une clé correspondant à une regex dans meta."""
    for key in meta:
        key_norm = key.lower().strip()
        for pat in patterns:
            if re.search(pat, key_norm):
                 return key, meta[key]
    return None, None

def safe_float(x):
    ''' return a float '''
    try:
        if isinstance(x, bytes):
            x = x.decode('utf-8', errors='ignore')
        return float(str(x).strip())
    except Exception:
        return None

def load_png(path_png,isAngle):
    ''' load data from a png container and its metadata, if isAngle is True datas are mapped 
    to [-π, π] '''
    im = Image.open(path_png)
    meta = dict(im.info)  # PNG metadatas

    # Metadata parsing
    _, pxw_val = find_meta_value(meta, [r'pixel *width', r'pixel.*x', r'physical.*pixel.*width'])
    _, pxh_val = find_meta_value(meta, [r'pixel *height', r'pixel.*y', r'physical.*pixel.*height'])
    _, pxunit_val = find_meta_value(meta, [r'pixel *unit', r'pixel.*unit', r'unit *pixel'])

    _, vmin_val = find_meta_value(meta, [r'value *min', r'min *value', r'phase *min'])
    _, vmax_val = find_meta_value(meta, [r'value *max', r'max *value', r'phase *max'])
    _, vunit_val = find_meta_value(meta, [r'value *unit', r'unit *value', r'phase *unit'])

    dx = safe_float(pxw_val)
    dy = safe_float(pxh_val)
    px_unit = str(pxunit_val).strip() if pxunit_val else None

    val_min = safe_float(vmin_val)
    val_max = safe_float(vmax_val)
    value_unit = str(vunit_val).strip() if vunit_val else None

    # image array converted tu unsigned 16 bit integer
    arr = np.array(im)
    if arr.dtype != np.uint16:
        arr = arr.astype(np.uint16)
        print("conversion to 16-bit done on image array")
    arr = arr.astype(np.float64)

    # Mapping
    if (val_min is not None) and (val_max is not None):
        val = val_min + (arr / 65535.0) * (val_max - val_min)
        note = f"Linear mapping 0..65535 -> [{val_min}, {val_max}] {value_unit or ''}"
    elif isAngle:
        val = (arr / 65535.0) * (2*np.pi) - np.pi
        note = "No Value Min/Max : mapping 0..65535 -> [-π, π]"

    print("→ Metadata:")
    if dx is not None and dy is not None:
        print(f"   Pixel Width  (dx) = {dx} {px_unit or ''}")
        print(f"   Pixel Height (dy) = {dy} {px_unit or ''}")
    else:
        print("   Pixel Width/Height not found")

    if val_min is not None and val_max is not None:
        print(f"   Value Min = {val_min} {value_unit or ''}")
        print(f"   Value Max = {val_max} {value_unit or ''}")
    else:
        print("   Value Min/Max not found")
    print(f"   Note : {note}\n")

    return val, dx, dy

def apply_window(phase, window_type='hann', width_fraction=0.1):
    """Applique une fenêtre sur les bords de l'image
    work in progress: to check
    """
    Ny, Nx = phase.shape
    
    # Largeur de la zone de transition
    wx = int(Nx * width_fraction)
    wy = int(Ny * width_fraction)
    
    # Création des fenêtres 1D
    win_x = np.ones(Nx)
    win_y = np.ones(Ny)
    
    if window_type == 'hann':
        win_x[:wx] = np.sin(np.linspace(0, np.pi/2, wx))**2
        win_x[-wx:] = np.sin(np.linspace(np.pi/2, 0, wx))**2
        win_y[:wy] = np.sin(np.linspace(0, np.pi/2, wy))**2
        win_y[-wy:] = np.sin(np.linspace(np.pi/2, 0, wy))**2
    
    # Fenêtre 2D
    window = np.outer(win_y, win_x)
    
    return phase * window

def simulate_fresnel_padded(phase, dx, dy, E0_eV=200e3, defocus=2e-6, Cs=1.2e-3, pad_factor=2):
    ''' compute a simulation of a fresnel contrast using padding
    it might be interesting to increase the number of zeros
    work in progress: is zero-padding efficient ?
    '''
    Ny, Nx = phase.shape
    lam = relativistic_wavelength(E0_eV)
    
    # Dimensions avec padding
    Ny_pad = Ny * pad_factor
    Nx_pad = Nx * pad_factor
    
    # Créer psi0 avec padding
    psi0 = np.exp(1j * phase)
    psi0_padded = np.zeros((Ny_pad, Nx_pad), dtype=complex)
    
    # Centrer l'image originale
    y_start = (Ny_pad - Ny) // 2
    x_start = (Nx_pad - Nx) // 2
    psi0_padded[y_start:y_start+Ny, x_start:x_start+Nx] = psi0
    
    # FFT sur le tableau paddé
    kx = np.fft.fftfreq(Nx_pad, d=dx)
    ky = np.fft.fftfreq(Ny_pad, d=dy)
    KX, KY = np.meshgrid(kx, ky)
    k2 = KX**2 + KY**2
    
    chi = np.pi*lam*defocus*k2 + 0.5*np.pi*Cs*(lam**3)*(k2**2)
    H = np.exp(-1j * chi)
    
    Psi0 = np.fft.fftshift(np.fft.fft2(np.fft.ifftshift(psi0_padded)))
    Psi_def = Psi0 * H
    psi_def = np.fft.fftshift(np.fft.ifft2(np.fft.ifftshift(Psi_def)))
    
    # Extraire la région centrale
    psi_def_crop = psi_def[y_start:y_start+Ny, x_start:x_start+Nx]
    
    return np.abs(psi_def_crop)**2

def detrend_phase(phase):
    """substract a baseline with a slope from phase
    """
    # not yet used anywhere
    Ny, Nx = phase.shape
    y, x = np.mgrid[0:Ny, 0:Nx]
    
    # Ajustement d'un plan
    A = np.c_[x.ravel(), y.ravel(), np.ones(Nx*Ny)]
    coef, _, _, _ = np.linalg.lstsq(A, phase.ravel(), rcond=None)
    
    plane = coef[0]*x + coef[1]*y + coef[2]
    return phase - plane

