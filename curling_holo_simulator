def exporter_cartes_16bits(phase_vals, thick_vals):
    """
    Génère, normalise et exporte les images 2D en niveaux de gris 16-bits
    (Carte de phase et Carte d'épaisseur) avec leurs métadonnées respectives.
    """
    # --- Récupération de la date et de l'heure actuelles ---
    maintenant = datetime.now()
    date_creation = maintenant.strftime("%Y-%m-%d")
    heure_creation = maintenant.strftime("%H:%M:%S")

    # -------------------------------------------------------------------------
    # EXPORT CARTE DE PHASE HOLOGRAPHIQUE (PNG 16-BITS) + MÉTADONNÉES
    # -------------------------------------------------------------------------
    phase_min, phase_max = np.min(phase_vals), np.max(phase_vals)
    print(f"[Image] Phase min : {phase_min:.4e} | Phase max : {phase_max:.4e}")

    # Normalisation linéaire stricte dans la dynamique de codage 16-bits [0, 65535]
    if phase_max != phase_min:
        phase_normalized = (phase_vals - phase_min) / (phase_max - phase_min) * 65535
    else:
        phase_normalized = np.zeros_like(phase_vals)

    # Mutation explicite du tableau vers le type d'entier non-signé 16 bits
    phase_16bit = phase_normalized.astype(np.uint16)

    # Création de la matrice bidimensionnelle 2D (invariance stricte de la phase selon l'axe z)
    phase_map_2d = np.tile(phase_16bit, (IMAGE_SIZE, 1))

    # Génération de l'image grayscale 16-bits
    img_phase = Image.fromarray(phase_map_2d)
    
    # --- Création de l'objet Métadonnées ---
    metadata_phase = PngInfo()
    metadata_phase.add_text("Simulation_Type", "Curling Holo Phase Simulator - Phase Map")
    # Ajout de la date et de l'heure
    metadata_phase.add_text("Creation_Date", date_creation)
    metadata_phase.add_text("Creation_Time", heure_creation)

    metadata_phase.add_text("Param_A", str(A))
    metadata_phase.add_text("Param_Ku", str(Ku))
    metadata_phase.add_text("Param_Ms", str(Ms))
    metadata_phase.add_text("Param_R", str(R))
    metadata_phase.add_text("Param_r0", str(r0))
    metadata_phase.add_text("Param_kappa", str(kappa))
    metadata_phase.add_text("Param_IMAGE_SIZE", str(IMAGE_SIZE))
   
    metadata_phase.add_text("Subject Units", "meters")
    metadata_phase.add_text("Pixel Width",  str(PIXEL_SIZE))
    metadata_phase.add_text("Pixel Height", str(PIXEL_SIZE))
    metadata_phase.add_text("Pixel Unit", "m")

    # Très important pour pouvoir refaire la simulation ou reconstruire les vraies valeurs de Phase :
    # On stocke les extrema qui ont servi à la normalisation [0, 65535]
    metadata_phase.add_text("Value Min", str(phase_min))
    metadata_phase.add_text("Value Max", str(phase_max))
    metadata_phase.add_text("Value Unit", "rad")

    # Sauvegarde forcée dans SCRIPT_DIR en transmettant l'objet pnginfo
    output_image_path_phase = os.path.join(SCRIPT_DIR, 'analytics_HOLO_PHASE.png')
    img_phase.save(output_image_path_phase, pnginfo=metadata_phase)

    print(f"[Succès] Image 16-bits (avec métadonnées) sauvegardée dans :\n -> {output_image_path_phase}")

    # Afficher l'image
    plt.imshow(img_phase, cmap="gray")
    # plt.axis("off")  # Masque les axes gradués (optionnel)
    plt.show()

    # -------------------------------------------------------------------------
    # EXPORT CARTE D'ÉPAISSEUR (PNG 16-BITS) + MÉTADONNÉES
    # -------------------------------------------------------------------------
    # --- VALEURS EXTREMA ---
    thick_min, thick_max = np.min(thick_vals), np.max(thick_vals)

    # Normalisation linéaire stricte dans la dynamique de codage 16-bits [0, 65535]
    if thick_max != thick_min:
        thick_normalized = (thick_vals - thick_min) / (thick_max - thick_min) * 65535
    else:
        thick_normalized = np.zeros_like(thick_vals)

    # Mutation explicite du tableau vers le type d'entier non-signé 16 bits
    thick_16bit = thick_normalized.astype(np.uint16)

    # Création de la matrice bidimensionnelle 2D (invariance stricte de la phase selon l'axe z)
    thick_map_2d = np.tile(thick_16bit, (IMAGE_SIZE, 1))

    # Génération de l'image grayscale 16-bits
    img_thick = Image.fromarray(thick_map_2d)

    # --- Création de l'objet Métadonnées ---
    metadata_thick = PngInfo()
    metadata_thick.add_text("Simulation_Type", "Curling Holo Phase Simulator - Thickness Map")
    # Ajout de la date et de l'heure
    metadata_phase.add_text("Creation_Date", date_creation)
    metadata_phase.add_text("Creation_Time", heure_creation)

    metadata_thick.add_text("Param_A", str(A))
    metadata_thick.add_text("Param_Ku", str(Ku))
    metadata_thick.add_text("Param_Ms", str(Ms))
    metadata_thick.add_text("Param_R", str(R))
    metadata_thick.add_text("Param_r0", str(r0))
    metadata_thick.add_text("Param_kappa", str(kappa))
    metadata_thick.add_text("Param_IMAGE_SIZE", str(IMAGE_SIZE))

    metadata_thick.add_text("Subject Units", "meters")
    metadata_thick.add_text("Pixel Width",  str(PIXEL_SIZE))
    metadata_thick.add_text("Pixel Height", str(PIXEL_SIZE))
    metadata_thick.add_text("Pixel Unit", "m")

    # Très important pour pouvoir refaire la simulation ou reconstruire les vraies valeurs de Phase :
    # On stocke les extrema qui ont servi à la normalisation [0, 65535]
    metadata_thick.add_text("Value Min", str(thick_min))
    metadata_thick.add_text("Value Max", str(thick_max))
    metadata_thick.add_text("Value Unit", "m")

    # Sauvegarde forcée dans SCRIPT_DIR en transmettant l'objet pnginfo
    output_image_path_thick = os.path.join(SCRIPT_DIR, 'analytics_PATH_LENGTH.png')
    img_thick.save(output_image_path_thick, pnginfo=metadata_thick)

    print(f"[Succès] Image 16-bits (avec métadonnées) sauvegardée dans :\n -> {output_image_path_thick}")

    # Afficher l'image
    plt.imshow(img_thick, cmap="gray")
    # plt.axis("off")  # Masque les axes gradués (optionnel)
    plt.show()


# =============================================================================
# 5. EXECUTION PRINCIPALE
# =============================================================================
if __name__ == "__main__":
   
    # 1. Gestion et parsing des arguments
    args = configurer_arguments()

    # --- Rendre les variables globales pour les fonctions du script ---
    global A, Ku, Ms, R, kappa, epsilon, r0, IMAGE_SIZE, PIXEL_SIZE

    # Récupération des arguments positionnels et optionnels
    IMAGE_SIZE = args.IMAGE_SIZE
    PIXEL_SIZE = args.PIXEL_SIZE
    A = args.A          # Constante d'échange (J/m)
    Ku = args.Ku        # Constante d'anisotropie uniaxiale (J/m^3)
    Ms = args.Ms        # Aimantation (A/m)
    R = args.R          # Rayon extérieur en m

    # --- Calcul des variables dépendantes ---
    r0 = R * 1e-6                  # Rayon de cœur (singularité numérique évitée), très petit devant R 
    kappa = (Ku * R**2) / (2 * A)  # grandeur adimensionnelle
    epsilon = r0 / R               # parametre adimensionnel

    # --- Affichage des arguments dans le terminal ---
    print("\n" + "="*50)
    print("PARAMÈTRES DE LA SIMULATION EN COURS :")
    print(f" -> IMAGE_SIZE : {IMAGE_SIZE}")
    print(f" -> PIXEL_SIZE : {PIXEL_SIZE:.2e} m")
    print(f" -> A  : {A:.2e} J/m")
    print(f" -> Ku : {Ku:.2e} J/m^3")
    print(f" -> Ms : {Ms:.2e} A/m")
    print(f" -> R  : {R:.2e} m")
    print(f" -> kappa (calculé)   : {kappa:.4f}\n")
    print("="*50 + "\n")

    # --- Détermination dynamique du répertoire du script ---
    # Cette variable pointe de manière absolue vers le dossier contenant ce fichier .py
    SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))

    # 2. Lancement des calculs physiques
    rho_grid, omega_bvp, y_vals, phase_vals, thick_vals = simuler_curling()

    # 3. Tracés graphiques de contrôle
    generer_graphiques(rho_grid, omega_bvp, y_vals, phase_vals)

    # 4. Normalisation et exportation au format PNG 16-bits avec métadonnées
    exporter_cartes_16bits(phase_vals, thick_vals)
