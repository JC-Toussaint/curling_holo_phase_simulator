N_BVP = 600       # Number of discretization points for the Euler-Lagrange equation


# =============================================================================
# 2. DIFFERENTIAL SYSTEM (EULER-LAGRANGE) & BOUNDARY CONDITIONS
# =============================================================================
def ode_curling(rho, y):
    """Definition of the dimensionless Euler-Lagrange
 ODE for the curling mode."""
    omega, domega_drho = y
    d2omega_drho2 = -domega_drho / rho + (1.0 / (2 * rho**2) + kappa) * np.sin(2 * omega)
    return np.vstack([domega_drho, d2omega_drho2])

def bc_curling(ya, yb):
    """Boundary conditions: omega(epsilon) = 0 and omega'(1) = 0."""
    return np.array([ya[0] - 0.0, yb[1] - 0.0])

# =============================================================================
# 2 bis. TOTAL ENERGY & MINIMIZATION FALLBACK
# =============================================================================
# When solve_bvp converges to a solution that is NOT monotonically increasing
# (which can happen because the Euler-Lagrange BVP admits several extrema of
# the energy functional, and the shooting/collocation method may lock onto a
# saddle point or a non-physical branch), we fall back to a direct
# minimization of the total micromagnetic energy E[omega], restricted to the
# subspace of monotonically non-decreasing profiles. This guarantees a
# physically admissible curling configuration.

def energie_totale(omega, rho_grid, A, kappa):
    """
    Computes the total energy E[omega] (in Joules) of a discretized profile
    omega(rho) sampled on rho_grid, following:

        E = 2*pi*A * int_eps^1 [ rho*(d(omega)/d(rho))^2
                                  + (1/rho + 2*kappa*rho) * sin^2(omega) ] d(rho)

    The derivative d(omega)/d(rho) is estimated with a numpy gradient
    (2nd-order accurate central differences) and the integral is evaluated
    with the trapezoidal rule.
    """
    domega_drho = np.gradient(omega, rho_grid)
    integrand = (rho_grid * domega_drho**2
                 + (1.0 / rho_grid + 2.0 * kappa * rho_grid) * np.sin(omega)**2)
    # np.trapz was renamed np.trapezoid in NumPy >= 2.0; support both.
    trapz_func = getattr(np, 'trapezoid', None) or np.trapz
    return 2.0 * np.pi * A * trapz_func(integrand, rho_grid)


def minimiser_energie_monotone(rho_grid, omega_init, A, kappa):
    """
    Minimizes the total energy E[omega] (see energie_totale) under the
    physical constraint that omega(rho) is monotonically non-decreasing,
    starting from the (non-monotonic) BVP solution as an initial guess.

    Monotonicity is enforced *by construction* via a change of variables:
    omega is written as the cumulative sum of non-negative increments
        omega_i = sum_{k<=i} softplus(x_k),   omega_0 = 0 (i.e. omega(epsilon)=0)
    where softplus(x) = log(1+exp(x)) >= 0 for any real x. This turns the
    constrained minimization into a free (unconstrained) minimization over
    the x_k, which L-BFGS-B handles efficiently and robustly.

    The Neumann condition omega'(1) = 0 is not imposed explicitly: it is the
    natural boundary condition of this variational problem and therefore
    emerges automatically at the minimum (the increments naturally shrink
    toward 0 near rho = 1 at the optimum).

    Returns:
        numpy.ndarray: the monotonic, energy-minimizing omega(rho) profile,
        evaluated on rho_grid.
    """
    def softplus(x):
        # Numerically stable softplus: log(1 + exp(x))
        return np.logaddexp(0.0, x)

    def omega_from_x(x):
        deltas = softplus(x)
        return np.concatenate(([0.0], np.cumsum(deltas)))

    def cout(x):
        return energie_totale(omega_from_x(x), rho_grid, A, kappa)

    # --- Initial guess: force the BVP profile to be non-decreasing first
    #     (running maximum), then invert the softplus to obtain x0 ---
    omega_init_mono = np.maximum.accumulate(omega_init)
    deltas_init = np.clip(np.diff(omega_init_mono), 1e-6, 50.0)
    x0 = np.log(np.expm1(deltas_init))  # inverse of softplus

    res = minimize(cout, x0, method='L-BFGS-B',
                    options={'maxiter': 5000, 'maxfun': 200000,
                             'ftol': 1e-15, 'gtol': 1e-12})

    omega_opt = omega_from_x(res.x)
    print(f"[Energy minimization] Convergence: {res.success} | "
          f"E_final = {res.fun:.6e} J | iterations = {res.nit}")

    return omega_opt


class MonotonicSplineWrapper:
    """
    Lightweight replacement for the callable returned by solve_bvp (sol.sol),
    built from a discretized, energy-minimized omega(rho) profile.

    Calling an instance with an array of rho values returns a (2, N) array
    stacking [omega(rho), domega/drho(rho)], exactly like sol.sol(rho) does,
    so it can be used as a drop-in replacement everywhere sol.sol is used
    (e.g. in integrand_z / compute_I).
    """
    def __init__(self, rho_grid, omega_vals):
        self._spline = CubicSpline(rho_grid, omega_vals)
        self._dspline = self._spline.derivative()

    def __call__(self, rho):
        rho = np.atleast_1d(rho)
        return np.vstack([self._spline(rho), self._dspline(rho)])


# =============================================================================
# 3. INTEGRATION FUNCTIONS FOR THE I(y) PROFILE
# =============================================================================
def integrand_z(z, y, R, sol_bvp):
    """Function to integrate along the z axis to obtain the I(y) profile."""
    r = np.sqrt(y**2 + z**2)
  
    rho = r / R
    
    # Safety clip to respect the spline's domain of definition [epsilon, 1.0]
    rho = np.clip(rho, epsilon, 1.0)
        
    # Evaluate omega(rho) via the spline object 'sol_bvp' generated by solve_bvp
    omega = sol_bvp(rho)[0]
    
    if r == 0:
        return 1.0
    return np.cos(omega)

def compute_I(y, R, sol_bvp):
    """Computes the integral projection I for
 a given y coordinate."""
    assert y>=0, 'y must be positive'
    if y>R: y=R
    bound = np.sqrt(R**2 - y**2)
    # Numerical integration with respect to z between -bound and +bound
    res, _ = quad(integrand_z, -bound, bound, args=(y, R, sol_bvp), limit=5000, epsabs=1e-10,
    epsrel=1e-10)
    return -mu_0 * Ms * res


