if __name__ == "__main__":
   
    # 1. Argument handling and parsing
    args = configurer_arguments()

    # --- Make the variables global for the script's functions ---
    global A, Ku, Ms, R, kappa, epsilon, r0, IMAGE_SIZE, PIXEL_SIZE

    # Retrieving positional and optional arguments
    IMAGE_SIZE = args.IMAGE_SIZE
    PIXEL_SIZE = args.PIXEL_SIZE
    A = args.A          # Exchange constant (J/m)
    Ku = args.Ku        # Uniaxial anisotropy constant (J/m^3)
    Ms = args.Ms        # Magnetization (A/m)
    R = args.R          # Outer radius in m

    # --- Computing dependent variables ---
    r0 = R * 1e-6                  # Core radius (numerical singularity avoided), very small compared to R
    kappa = (Ku * R**2) / (2 * A)  # dimensionless quantity
    epsilon = r0 / R               # dimensionless parameter

    # --- Displaying the arguments in the terminal ---
    print("\n" + "="*50)
    print("PARAMETERS OF THE CURRENT SIMULATION:")
    print(f" -> IMAGE_SIZE : {IMAGE_SIZE}")
    print(f" -> PIXEL_SIZE : {PIXEL_SIZE:.2e} m")
    print(f" -> A  : {A:.2e} J/m")
    print(f" -> Ku : {Ku:.2e} J/m^3")
    print(f" -> Ms : {Ms:.2e} A/m")
    print(f" -> R  : {R:.2e} m")
    print(f" -> kappa (computed)  : {kappa:.4f}\n")
    print("="*50 + "\n")

    # --- Dynamic determination of the script's directory ---
    # This variable points absolutely to the folder containing this .py file
    SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))

    # 2. Launching the physical computations
    rho_grid, omega_bvp, y_vals, phase_vals, thick_vals = simuler_curling()

    # 3. Control plots
    generer_graphiques(rho_grid, omega_bvp, y_vals, phase_vals)

    # 4. Normalization and export to 16-bit PNG format with metadata
    exporter_cartes_16bits(phase_vals, thick_vals)
