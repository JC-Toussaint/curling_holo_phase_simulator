    """
    description_text = "Solving the curling mode with custom parameters."
    
    exemples = """
    usage examples:
         %(prog)s 1000 2e-10 --Ku=-1e4 --R 100e-9
         %(prog)s 1000 2e-10 --A 1.5e-11 --Ku=-2e4 --R 100e-9
    """

    #parser = argparse.ArgumentParser(
    #    description=description_text,
    #    epilog=exemples,
    #    formatter_class=argparse.RawDescriptionHelpFormatter,
    #    prefix_chars='-+'  # Better handling of plus and minus signs
    #)

    parser = argparse.ArgumentParser(
        description=description_text,
        epilog=exemples,
        formatter_class=CustomHelpFormatter,
        prefix_chars='-+' # Better handling of plus and minus signs
    )

    # Required positional arguments
    parser.add_argument('IMAGE_SIZE', type=int, help="Final size of the PNG image (IMAGE_SIZE x IMAGE_SIZE)")
    parser.add_argument('PIXEL_SIZE', type=float, help="Size of a pixel in meters (replaces dx and dy)")

    # Optional arguments
    parser.add_argument('--A',  type=float, default = 1.3e-11, help="Exchange constant (J/m)")
    parser.add_argument('--Ku', type=float, default = -1e4, help="Uniaxial anisotropy constant (J/m^3)")
    parser.add_argument('--Ms', type=float, default = 1.00531 / mu_0, help="Magnetization (A/m)")
    parser.add_argument('--R',  type=float, default = 100e-9, help="Outer radius of the cylinder (m)")

    if len(sys.argv) == 1:
        parser.print_help()
        sys.exit(0)

    return parser.parse_args()


def simuler_curling():
    """
    Runs the core physical simulation: stability diagnostics,
    solving the boundary value problem (BVP), computing the integral projection,
    and computing the holographic phase.
    
    Returns:
        tuple: (rho_grid, omega_bvp, y_vals, phase_vals, thick_vals)
    """
    # --- Step A: Solution estimate and stability diagnostics ---
    if Ku != 0:
        l_K = np.sqrt(A / abs(Ku))
        Rc = 1.8412 * l_K
        print(f"Estimated critical radius R_c = {Rc*1e9:.2f} nm (current R = {R*1e9:.1f} nm)")
 
        if Ku > 0 or R < Rc:
            print(">>> Warning: Stable configuration expected toward the trivial solution omega(rho) = 0.")
        else:
            print(">>> Favorable configuration: Non-trivial curling profile expected.")

    # --- Step B: Solving the ODE (BVP) ---
    rho_grid = np.linspace(epsilon, 1.0, N_BVP)
    # Linear 'guess' profile to push the solver toward the non-trivial solution
    if Ku < 0:
        # omega_guess = (np.pi / 2) * rho_grid 
        omega_guess = (np.pi / 2) * np.tanh(rho_grid*(2-rho_grid))
    else:
        omega_guess = 0 * rho_grid
    y_guess = np.vstack([omega_guess, np.gradient(omega_guess, rho_grid)])

    sol = solve_bvp(ode_curling, bc_curling, rho_grid, y_guess, tol=1e-7, max_nodes=1000000)
    print("[Euler-Lagrange / BVP] Convergence status:", sol.message)
    omega_bvp = sol.sol(rho_grid)[0]

    # --- Step B bis: Check that omega(rho) is monotonically increasing ---
    # Derivative of omega with respect to rho, evaluated on the grid via the spline
    domega_drho_bvp = sol.sol(rho_grid)[1]

    # By default, the interpolator used downstream is the one produced by solve_bvp.
    # It is replaced below by an energy-minimized, monotonic profile if the
    # BVP solution turns out not to be physically admissible.
    sol_final = sol.sol

    if np.all(domega_drho_bvp >= -1e-12):  # numerical tolerance
        print("[Monotonicity] omega(rho) is increasing over the entire domain.")
    else:
        print("\n" + "="*50)
        print("[Monotonicity] WARNING: omega(rho) is not monotonically increasing over the domain.")
        print("The BVP solution does not satisfy the expected physical behavior.")
        print("Falling back to a direct minimization of the total energy E[omega],")
        print("restricted to monotonically increasing profiles.")
        print("="*50 + "\n")

        # omega_opt = minimiser_energie_monotone(rho_grid, omega_bvp, A, kappa)
        omega_opt = minimiser_energie_monotone(rho_grid, omega_guess, A, kappa)

        # Rebuild a sol_bvp-like callable (omega, domega/drho) from the
        # energy-minimized profile, used everywhere sol.sol was used before.
        sol_final = MonotonicSplineWrapper(rho_grid, omega_opt)

        # Update omega_bvp so that the control plots and the returned tuple
        # reflect the final (physically admissible) configuration.
        omega_bvp = sol_final(rho_grid)[0]

        # Final monotonicity check on the minimized profile (sanity check)
        domega_drho_opt = sol_final(rho_grid)[1]
        if np.all(domega_drho_opt >= -1e-9):
            print("[Monotonicity] omega(rho) is increasing over the entire domain "
                  "after energy minimization.")
        else:
            print("[Monotonicity] WARNING: residual non-monotonicity remains after "
                  "minimization (numerical tolerance may need adjustment).")

    # --- Step C: Computing the integration profile I(y) ---
    # Vectorization of the function for optimized execution over a NumPy array
    compute_I_vectorized = np.vectorize(lambda y: compute_I(y, R, sol_final))
    
    # Direct generation of the fine mesh (avoids computing twice with different grid sizes)
    bound = IMAGE_SIZE * PIXEL_SIZE / 2
    y_vals = np.linspace(0, bound, IMAGE_SIZE // 2 + 1)
    print(f"[Computation] Evaluating I(y) over {IMAGE_SIZE} points...")
    I_vals = compute_I_vectorized(y_vals)

    # --- Step D: Computing the phase Phi(y) ---
    # Integration using the trapezoidal method
    phase_vals = cumulative_trapezoid(I_vals, y_vals, initial=0)
    phase_vals *= -e_c / hbar

    # anti-symmetrization
    y_vals = np.concatenate((-y_vals[:1:-1], y_vals))
    phase_vals = np.concatenate((-phase_vals[:1:-1], phase_vals))

    # Computing the thickness profile
    thick_vals = 2 * np.sqrt(np.maximum(0, R**2 - y_vals**2))

    return rho_grid, omega_bvp, y_vals, phase_vals, thick_vals


